<?xml version="1.0" encoding="utf-8"?>
<!-- Piper v2 kinematic-only URDF (matches piper_v2.usd) -->
<robot name="piper_v2">
  <link name="arm_base"/>
  <link name="link1"/>
  <link name="link2"/>
  <link name="link3"/>
  <link name="link4"/>
  <link name="link5"/>
  <link name="link6"/>

  <joint name="joint1" type="revolute">
    <origin xyz="0 0 0.123" rpy="0 0 -1.5708"/>
    <parent link="arm_base"/>
    <child link="link1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.6180" upper="2.6180" effort="100" velocity="5"/>
  </joint>

  <joint name="joint2" type="revolute">
    <origin xyz="0 0 0" rpy="1.5708 -0.034907 -1.5708"/>
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="3.1416" effort="100" velocity="5"/>
  </joint>

  <joint name="joint3" type="revolute">
    <origin xyz="0.28358 0.028726 0" rpy="0 0 0.06604341"/>
    <parent link="link2"/>
    <child link="link3"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.9671" upper="0" effort="100" velocity="5"/>
  </joint>

  <joint name="joint4" type="revolute">
    <origin xyz="-0.24221 0.068514 0" rpy="-1.5708 0 1.3826"/>
    <parent link="link3"/>
    <child link="link4"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.6580" upper="1.6580" effort="100" velocity="5"/>
  </joint>

  <joint name="joint5" type="revolute">
    <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <parent link="link4"/>
    <child link="link5"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.8326" upper="1.8326" effort="100" velocity="5"/>
  </joint>

  <joint name="joint6" type="revolute">
    <origin xyz="0 0.091 0.0014165" rpy="-1.5708 -1.5708 0"/>
    <parent link="link5"/>
    <child link="link6"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.7925" upper="2.7925" effort="100" velocity="5"/>
  </joint>

  <!-- Gripper center: midpoint between fingertips, 0.13503m along link6 Z -->
  <link name="gripper_center"/>
  <joint name="link6_to_gripper_center" type="fixed">
    <origin xyz="0 0 0.13503" rpy="0 0 0"/>
    <parent link="link6"/>
    <child link="gripper_center"/>
  </joint>
</robot>
